{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Local FastAPI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/src/main.py",
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": false,
            "jinja": true
        },
        {
            "name": "Python: Attach Docker (Backend)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/backend/src",
                    "remoteRoot": "/app/src"
                }
            ],
            "justMyCode": false,
            "jinja": true
        }
    ]
}
